{
  "name": "codice",
  "version": "1.0.0",
  "module": "src/cli/main.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "dev": "bun run src/cli/main.ts --verbose",
    "build": "bun build --compile src/cli/main.ts --outfile ./dist/codice",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "biome check src/ tests/",
    "format": "biome format --write src/ tests/",
    "format:check": "biome format --check src/ tests/"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "semver": "^7.8.4"
  }
}
